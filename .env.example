# Example environment variables for local development.
# Copy this file to `.env` and fill real values. Do NOT commit secrets.

# API Configuration
EXPO_PUBLIC_API_URL=http://localhost:3000/api/v1

# Cloudinary and Google Sign-In client ID now come from backend endpoint:
# GET /api/v1/mobile-config
# Do not store these values in mobile env anymore.
#
# iOS requires a dedicated OAuth iOS Client ID when using
# @react-native-google-signin/google-signin without GoogleService-Info.plist.
# This value is safe to expose as EXPO_PUBLIC_*.
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=

# Store URLs for update prompts
EXPO_PUBLIC_APP_STORE_URL=https://apps.apple.com/app/idXXXXXXXXX
EXPO_PUBLIC_PLAY_STORE_URL=https://play.google.com/store/apps/details?id=com.example.app

# Geolocation provider key was moved to backend proxy.
# Do not define EXPO_PUBLIC_IP_API_KEY in the mobile app.

